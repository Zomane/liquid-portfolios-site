# Local async SQLite database.
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# Use "production" only on HTTPS hosting.
ENVIRONMENT=development

# Discord bot token from Developer Portal -> Bot.
DISCORD_TOKEN=

# Your Discord server ID. Leave DISCORD_GUILD_IDS empty for one server.
DISCORD_GUILD_ID=
DISCORD_GUILD_IDS=

# Discord OAuth2 app credentials and callback URL.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8000/api/auth/callback
FRONTEND_URL=http://localhost:5173

# Random app secret for JWT/CSRF tokens.
JWT_SECRET=

# Optional Twitter API key. Empty means Twitter stats/profile fallback is used.
TWITTER_API_KEY=

# Local message stats storage.
MESSAGES_DB_PATH=./data/messages.db

# Demo-friendly cooldowns.
RESUBMIT_COOLDOWN_MINUTES=0
PROMOTION_COOLDOWN_MINUTES=0
